# Database (any Postgres). In prod use the pooled connection string (Neon, etc.).
# For a local Postgres without TLS, append ?sslmode=disable or set DATABASE_SSL=disable.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Admin auth
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SESSION_SECRET=long-random-string-used-to-sign-the-admin-cookie

# Resend Configuration
RESEND_API_KEY=your-resend-api-key

# Application Configuration
NEXT_PUBLIC_MAX_COMEDIAN_SLOTS=20
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_EMAIL=your-app-email@example.com
EXTRA_NOTIFY_EMAIL=your-notification-email@example.com